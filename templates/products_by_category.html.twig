{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - Products{% endblock %}

{% block body %}
    <!-- Category Header -->
    <div class="container my-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_categories') }}" class="text-decoration-none">Categories</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ category.name }}</li>
            </ol>
        </nav>
        <h1 class="mb-4">Products in {{ category.name }}</h1>
    </div>

    <!-- Products Grid -->
    <div class="container my-5">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
            <!-- Product -->
            <div class="col">
                <div class="card h-100">
                    <img src="{{ asset('assets/images/item.png') }}" class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ category.name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text fw-bold text-success">${{ product.price }}</p>
                        <a href="{{ path('app_product_details', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
