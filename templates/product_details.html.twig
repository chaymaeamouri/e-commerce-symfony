{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Details{% endblock %}

{% block body %}
    <!-- Product Details Section -->
    <div class="container my-5">
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-6">
                <img src="{{ asset('assets/images/item.png') }}" class="img-fluid rounded" alt="{{ product.name }}">
            </div>

            <!-- Product Information -->
            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}" class="text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Product Details</li>
                    </ol>
                </nav>

                {# Affichage conditionnel de la catégorie avec badge info au lieu de primary #}
                {% if product.category %}
                    <span class="badge bg-info mb-3">{{ product.category.name }}</span>
                {% endif %}
                
                <h1 class="mb-3">{{ product.name }}</h1>
                
                <h3 class="text-success mb-4">${{ product.price }}</h3>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p class="text-muted">
                        {{ product.description }}
                    </p>
                </div>

                <!-- Add to Cart Form -->
                <form action="{{ path('cart_add', {id: product.id}) }}" method="get">
                    <div class="mb-3">
                        <label for="quantity" class="form-label">Quantity</label>
                        <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="10" style="max-width: 100px;">
                    </div>

                    <div class="d-grid gap-2 d-md-flex">
                        {# Changement du bouton d'ajout au panier en btn-info pour le style #}
                        <button type="submit" class="btn btn-info text-white btn-lg">Add to Cart</button>
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg">Continue Shopping</a>
                    </div>
                </form>

                <!-- Additional Info -->
                <div class="mt-4 pt-4 border-top">
                    <ul class="list-unstyled">
                        <li class="mb-2"><strong>SKU:</strong> PRD-{{ product.id }}</li>
                        <li class="mb-2"><strong>Availability:</strong> <span class="text-success">In Stock</span></li>
                        <li class="mb-2"><strong>Category:</strong> {{ product.category ? product.category.name : 'N/A' }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
