{% extends 'base.html.twig' %}

{% block title %}Browse Categories - Our Store{% endblock %}

{% block body %}
    <!-- Categories Hero Section -->
    <div class="bg-light py-5">
        <div class="container text-center">
            <h1 class="display-4 fw-bold">Browse Our Categories</h1>
            <p class="lead text-muted">Find exactly what you're looking for by browsing our curated collections.</p>
        </div>
    </div>

    <!-- Categories Grid -->
    <div class="container my-5">
    <!-- Hero Section -->
    <div class="bg-primary bg-gradient text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-3 fw-bold mb-4">Welcome to Our Store</h1>
                    <p class="lead mb-4">Discover amazing products across all categories. Quality items at unbeatable prices.</p>
                    <a href="{{ path('app_home') }}" class="btn btn-light btn-lg me-2">Shop Now</a>
                    <a href="#categories" class="btn btn-outline-light btn-lg">Browse Categories</a>
                </div>
                <div class="col-lg-6 text-center d-none d-lg-block">
                    <img src="{{ asset('assets/images/item.png') }}" class="img-fluid rounded" alt="Shopping" style="max-height: 300px;">
                </div>
            </div>
        </div>
    </div>

    <!-- Categories Section -->
    <div class="container my-5" id="categories">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Shop by Category</h2>
            <p class="text-muted">Explore our wide range of products organized by category</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for category in categories %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">{{ category.products|length }} Products</span>
                        <h4 class="card-title">{{ category.name }}</h4>
                        <p class="card-text text-muted">Explore items in {{ category.name }}</p>
                        <a href="{{ path('app_products_by_category', {id: category.id}) }}" class="btn btn-outline-primary">Browse {{ category.name }}</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
