{% extends 'base.html.twig' %}

{% block title %}Shopping Cart - Our Store{% endblock %}

{% block body %}
    <!-- Cart Section -->
    <div class="container my-5">
        <h1 class="mb-4">Your Shopping Cart</h1>
        
        <div class="row">
            <!-- Cart Items -->
            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="table-responsive">
                        {# Changement de table-hover à table-striped pour différencier le design #}
                        <table class="table table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {# Boucle sur les éléments du panier #}
                                {% for item in items %}
                                <!-- Cart Item -->
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="{{ asset('assets/images/item.png') }}" class="img-thumbnail me-3" alt="{{ item.product.name }}" style="width: 80px; height: 80px; object-fit: cover;">
                                            <div>
                                                <h6 class="mb-0">{{ item.product.name }}</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td>${{ item.product.price }}</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <a href="{{ path('cart_decrement', {id: item.product.id}) }}" class="btn btn-sm btn-outline-secondary me-2">-</a>
                                            <span>{{ item.quantity }}</span>
                                            <a href="{{ path('cart_add', {id: item.product.id}) }}" class="btn btn-sm btn-outline-secondary ms-2">+</a>
                                        </div>
                                    </td>
                                    <td class="fw-bold">${{ item.product.price * item.quantity }}</td>
                                    <td>
                                        <a href="{{ path('cart_remove', {id: item.product.id}) }}" class="btn btn-sm btn-outline-danger">Remove</a>
                                    </td>
                                </tr>
                                {# Bloc exécuté si le panier est vide (items est vide) #}
                                {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-4">Your cart is empty</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <a href="{{ path('app_home') }}" class="btn btn-link text-decoration-none p-0">
                    Continue Shopping
                </a>
                {# Affiche le bouton "Clear Cart" uniquement s'il y a des articles #}
                {% if items|length > 0 %}
                <a href="{{ path('cart_clear') }}" class="btn btn-outline-danger float-end">Clear Cart</a>
                {% endif %}
            </div>

            <!-- Order Summary -->
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span>${{ total }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping:</span>
                            <span>Free</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total:</strong>
                            <strong class="text-primary">${{ total }}</strong> {# Changement de text-success à text-primary #}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
